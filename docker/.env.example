# Copy this file to .env in the same directory (docker/) and fill in real values
# before running docker compose up. Never commit the real .env file.

# Shared HMAC secret used by user-service to SIGN access tokens and by
# farm-twin-service to VERIFY them. Must be at least 256 bits (32+ ASCII
# characters) for HS256. Generate one with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-real-256-bit-secret-before-running-in-anything-but-local-dev
